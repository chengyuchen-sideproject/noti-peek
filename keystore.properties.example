# Copy this file to `keystore.properties` and fill in your real values.
# `keystore.properties` is git-ignored and must NEVER be committed.
#
# Generate the keystore first (keep the .jks file and these passwords safe -
# you need the SAME key to publish every future update of the app):
#
#   keytool -genkeypair -v -keystore notipeek-release.jks \
#           -alias notipeek -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the project root.

storeFile=notipeek-release.jks
storePassword=your-store-password
keyAlias=notipeek
keyPassword=your-key-password
